
@model LoginDto

@{
    ViewBag.Title = "Login";
}

<style>
    html, body {
        height: 100%;
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 16px;
    }

    .ui-bg-primary {
        background-color: #c75b2a; /* naranja menos saturado */
    }

    .video-panel {
        height: 90vh;
        position: relative;
        overflow: hidden;
    }

        .video-panel img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.7); /* oscurece la imagen para destacar formulario */
        }

    .login-panel {
        height: 90vh;
        background-color: rgba(255, 255, 245, 0.95); /* fondo cálido semi-transparente */
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        display: flex !important;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

        .login-panel > div {
            max-width: 400px;
            width: 100%;
        }

    .bi-person-circle {
        font-size: 120px;
        color: #6c757d;
        margin-bottom: 1rem;
    }

    label {
        font-weight: 600;
        color: #333;
        font-size: 0.9rem;
    }

    .form-control {
        border: 1.5px solid #198754; /* verde bootstrap estándar */
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
        font-size: 1rem;
        transition: border-color 0.3s ease;
    }

        .form-control:focus {
            border-color: #14532d;
            box-shadow: 0 0 5px rgba(25, 135, 84, 0.5);
            outline: none;
        }

    .btn.boton {
        background-color: #198754;
        border-color: #198754;
        color: white;
        font-size: 1.1rem;
        padding: 0.5rem 1.5rem;
        border-radius: 0.375rem;
        transition: background-color 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 3px 8px rgba(25, 135, 84, 0.4);
    }

        .btn.boton:hover {
            background-color: #14532d;
            border-color: #14532d;
            box-shadow: 0 5px 15px rgba(20, 83, 45, 0.7);
            color: white;
        }

    /* Ajuste espaciado */
    .form-group {
        margin-bottom: 1rem;
    }
</style>

<div class="row min-vh-100 m-0 justify-content-center align-items-center">

    <div class="col-lg-6 p-0 video-panel">
        <img src="~/img/img1.jpg" alt="Imagen camión en carretera" />
    </div>

    <div class="col-lg-4 px-4 login-panel">
        <div>
            <div class="text-center">
                <i class="bi bi-person-circle"></i>
            </div>

            <form asp-controller="Auth" asp-action="Login" method="POST" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="form-group">
                    <label asp-for="Username">Usuario</label>
                    <input asp-for="Username" class="form-control" placeholder="Ingrese su usuario" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Contraseña</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Ingrese su contraseña" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mt-4 text-center">
                    <button type="submit" id="btnLogin" class="btn boton btn-lg">Ingresar</button>
                </div>
            </form>
        </div>
    </div>
</div>
